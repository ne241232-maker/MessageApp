
<!DOCTYPE HTML>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Message App</title>
  </head>
  <body>
    <h1>
      データベースを検索する
    </h1>
    <p>
      <a href="./">Topに戻る</a>
    </p>
    <form action="./search" method="post">
      <input id="searchText" name="searchText" size="20">
      <button id="submitSearch" type="submit" name="submitButton">検索</button>
    </form>
    <p>検索結果</p>
    <hr>
    <%for (let i = 0; i < results.length; i++) {%>
      <p><%= results[i] %></p>
    <%}%>
  </body>
</html>
    